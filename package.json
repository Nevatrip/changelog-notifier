{
  "name": "changelog-notifier",
  "version": "2.4.4",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build index.js -o dist --license licenses.txt",
    "release": "VERSION=$(node -p \"require('./package.json').version\") && git tag \"v$VERSION\" && git tag -f latest && git push origin \"v$VERSION\" && git push origin latest --force",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3",
    "jest": "^30.2.0"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "index.js"
    ]
  }
}